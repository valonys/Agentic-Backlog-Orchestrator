# Backend Environment Variables
# Copy this file to .env and fill in your values

# ── OpenRouter (proxy — routes to minimax/mm-m2 and many others) ─────────────
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=minimax/mm-m2

# ── DeepSeek (standalone — https://platform.deepseek.com) ────────────────────
DEEPSEEK_API_KEY=
# Model options: deepseek-chat | deepseek-reasoner

# ── Anthropic (standalone — https://console.anthropic.com) ───────────────────
ANTHROPIC_API_KEY=
# Model options: claude-opus-4-5 | claude-sonnet-4-5 | claude-haiku-3-5

# ── Google Gemini (standalone — https://aistudio.google.com/apikey) ──────────
GEMINI_API_KEY=
# Model options: gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash

# ── LLM tuning ───────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=3000

# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
BACKEND_PORT=8000
